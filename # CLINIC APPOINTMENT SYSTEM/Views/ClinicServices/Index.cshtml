@model IEnumerable<ClinicAppointmentSystem.Models.ClinicService>

@{
    ViewData["Title"] = "Clinic Services";
}

<style>
    .glass-container {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 20px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
        padding: 40px;
        margin-top: 50px;
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .service-card {
        background: rgba(255, 255, 255, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 15px;
        padding: 20px;
        transition: all 0.3s ease;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .service-card:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        background: rgba(255, 255, 255, 0.8);
    }

    .price-tag {
        font-weight: bold;
        color: #2c3e50;
        font-size: 1.25rem;
        background: #e0f2f1;
        padding: 5px 15px;
        border-radius: 20px;
    }

    .btn-glass-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 10px 25px;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .btn-glass-primary:hover {
        opacity: 0.9;
        color: white;
        transform: translateY(-2px);
    }

    .action-icons a {
        margin-left: 10px;
        color: #34495e;
        font-size: 1.1rem;
        transition: color 0.3s;
    }

    .action-icons a:hover {
        color: #667eea;
    }
</style>

<div class="container">
    <div class="glass-container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-5 fw-bold text-dark mb-0">Clinic Services</h1>
                <p class="text-muted">Manage available services and healthcare pricing.</p>
            </div>
            <a asp-action="Create" class="btn btn-glass-primary shadow">
                <i class="fas fa-plus me-2"></i> Add New Service
            </a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-notes-medical fa-3x text-muted mb-3"></i>
                <p class="h5 text-muted">No services defined yet.</p>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-12">
                        <div class="service-card shadow-sm">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                                    <i class="fas fa-stethoscope text-primary h4 mb-0"></i>
                                </div>
                                <div>
                                    <h4 class="mb-1 fw-bold text-dark">@item.Name</h4>
                                    <p class="small text-muted mb-0">@item.Description</p>
                                </div>
                            </div>
                            
                            <div class="d-flex align-items-center">
                                <div class="price-tag me-4">
                                    $@item.Price
                                </div>
                                <div class="action-icons">
                                    <a asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" title="Delete" class="text-danger"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
