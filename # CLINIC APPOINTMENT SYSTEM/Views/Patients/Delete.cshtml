@model ClinicAppointmentSystem.Models.Patient

@{
    ViewData["Title"] = "Delete Patient";
}

<h2>Delete Patient</h2>

<h3>Are you sure you want to delete this patient?</h3>
<div class="card bg-light mt-4 shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class = "col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
            <dd class = "col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
            <dt class = "col-sm-3">Date of Birth</dt>
            <dd class = "col-sm-9">@Model.DOB.ToShortDateString()</dd>
            <dt class = "col-sm-3">@Html.DisplayNameFor(model => model.Contact)</dt>
            <dd class = "col-sm-9">@Html.DisplayFor(model => model.Contact)</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-4" onsubmit="return confirm('Please confirm you want to permanently delete this record.');">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
