@model ClinicAppointmentSystem.Models.Patient

@{
    ViewData["Title"] = "Add Patient";
}

<h2>Add Patient</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="DOB" class="control-label">Date of Birth</label>
                <input asp-for="DOB" class="form-control" type="date" />
                <span asp-validation-for="DOB" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Contact" class="control-label fw-bold">Phone Number (Include Country Code)</label>
                <input asp-for="Contact" class="form-control" placeholder="+1 234 567 8900" type="tel" />
                <span asp-validation-for="Contact" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Address" class="control-label fw-bold">Residential Address</label>
                <input asp-for="Address" class="form-control" placeholder="123 Hospital St, City, Country" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="MedicalHistory" class="control-label fw-bold">Medical History</label>
                <textarea asp-for="MedicalHistory" class="form-control" rows="3"></textarea>
                <span asp-validation-for="MedicalHistory" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Add Patient" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
