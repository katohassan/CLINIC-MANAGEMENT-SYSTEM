@model ClinicAppointmentSystem.Models.Patient

@{
    ViewData["Title"] = "Register Patient";
}

<h2>Register Patient</h2>
<hr />
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="MiddleName" class="form-label"></label>
            <input asp-for="MiddleName" class="form-control" />
            <span asp-validation-for="MiddleName" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
            <input asp-for="DateOfBirth" class="form-control" type="date" />
            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Gender" class="form-label"></label>
            <select asp-for="Gender" class="form-control">
                <option value="0">Unknown</option>
                <option value="1">Male</option>
                <option value="2">Female</option>
                <option value="3">Other</option>
            </select>
            <span asp-validation-for="Gender" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="NationalId" class="form-label">National ID / Passport</label>
            <input asp-for="NationalId" class="form-control" />
            <span asp-validation-for="NationalId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="PrimaryPhone" class="form-label">Primary Phone</label>
            <input asp-for="PrimaryPhone" class="form-control" />
            <span asp-validation-for="PrimaryPhone" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="SecondaryPhone" class="form-label">Secondary Phone</label>
            <input asp-for="SecondaryPhone" class="form-control" />
            <span asp-validation-for="SecondaryPhone" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" type="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Address</label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <h5>Emergency Contact</h5>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="EmergencyContact.Name" class="form-label">Name</label>
            <input asp-for="EmergencyContact.Name" class="form-control" />
            <span asp-validation-for="EmergencyContact.Name" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="EmergencyContact.Relationship" class="form-label">Relationship</label>
            <input asp-for="EmergencyContact.Relationship" class="form-control" />
            <span asp-validation-for="EmergencyContact.Relationship" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="EmergencyContact.Phone" class="form-label">Phone</label>
            <input asp-for="EmergencyContact.Phone" class="form-control" />
            <span asp-validation-for="EmergencyContact.Phone" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Allergies" class="form-label">Allergies</label>
        <input asp-for="Allergies" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="ChronicConditions" class="form-label">Chronic Conditions</label>
        <input asp-for="ChronicConditions" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Surgeries" class="form-label">Past Surgeries</label>
        <input asp-for="Surgeries" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="CurrentMedications" class="form-label">Current Medications</label>
        <input asp-for="CurrentMedications" class="form-control" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="InsuranceProvider" class="form-label">Insurance Provider</label>
            <input asp-for="InsuranceProvider" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="PolicyNumber" class="form-label">Policy Number</label>
            <input asp-for="PolicyNumber" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="PreferredDoctorId" class="form-label">Preferred Doctor</label>
        <select asp-for="PreferredDoctorId" class="form-control" asp-items="@(new SelectList(ViewBag.Doctors as IEnumerable<ClinicAppointmentSystem.Models.Doctor>, "Id", "FullName"))">
            <option value="">-- None --</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="ReasonForVisit" class="form-label">Reason For Visit</label>
        <textarea asp-for="ReasonForVisit" class="form-control"></textarea>
    </div>

    <div class="form-check mb-2">
        <input asp-for="ConsentDataPrivacy" class="form-check-input" />
        <label asp-for="ConsentDataPrivacy" class="form-check-label">Agree to Data Privacy</label>
    </div>
    <div class="form-check mb-2">
        <input asp-for="ConsentTreatment" class="form-check-input" />
        <label asp-for="ConsentTreatment" class="form-check-label">Agree to Treatment</label>
    </div>
    <div class="form-check mb-3">
        <input asp-for="ConsentBilling" class="form-check-input" />
        <label asp-for="ConsentBilling" class="form-check-label">Agree to Billing</label>
    </div>

    <div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
