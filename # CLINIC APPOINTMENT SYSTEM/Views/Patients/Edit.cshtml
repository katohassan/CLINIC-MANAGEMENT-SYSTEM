@model ClinicAppointmentSystem.Models.Patient

@{
    ViewData["Title"] = "Edit Patient";
}

<h2>Edit Patient</h2>
<hr />
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="MiddleName" class="form-label"></label>
            <input asp-for="MiddleName" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
            <input asp-for="DateOfBirth" class="form-control" type="date" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Gender" class="form-label">Gender</label>
            <select asp-for="Gender" class="form-control">
                <option value="0">Unknown</option>
                <option value="1">Male</option>
                <option value="2">Female</option>
                <option value="3">Other</option>
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="NationalId" class="form-label">National ID / Passport</label>
            <input asp-for="NationalId" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="PrimaryPhone" class="form-label">Primary Phone</label>
        <input asp-for="PrimaryPhone" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="SecondaryPhone" class="form-label">Secondary Phone</label>
        <input asp-for="SecondaryPhone" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" type="email" />
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Allergies" class="form-label">Allergies</label>
        <input asp-for="Allergies" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="ChronicConditions" class="form-label">Chronic Conditions</label>
        <input asp-for="ChronicConditions" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Surgeries" class="form-label">Past Surgeries</label>
        <input asp-for="Surgeries" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="CurrentMedications" class="form-label">Current Medications</label>
        <input asp-for="CurrentMedications" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="InsuranceProvider" class="form-label">Insurance Provider</label>
        <input asp-for="InsuranceProvider" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="PolicyNumber" class="form-label">Policy Number</label>
        <input asp-for="PolicyNumber" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="ReasonForVisit" class="form-label">Reason For Visit</label>
        <textarea asp-for="ReasonForVisit" class="form-control"></textarea>
    </div>

    <div class="form-check mb-2">
        <input asp-for="ConsentDataPrivacy" class="form-check-input" />
        <label asp-for="ConsentDataPrivacy" class="form-check-label">Agree to Data Privacy</label>
    </div>
    <div class="form-check mb-2">
        <input asp-for="ConsentTreatment" class="form-check-input" />
        <label asp-for="ConsentTreatment" class="form-check-label">Agree to Treatment</label>
    </div>
    <div class="form-check mb-3">
        <input asp-for="ConsentBilling" class="form-check-input" />
        <label asp-for="ConsentBilling" class="form-check-label">Agree to Billing</label>
    </div>

    <div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
