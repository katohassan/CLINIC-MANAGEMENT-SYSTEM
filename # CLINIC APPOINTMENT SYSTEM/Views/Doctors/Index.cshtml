@model IEnumerable<ClinicAppointmentSystem.Models.Doctor>

@{
    ViewData["Title"] = "Manage Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Doctors</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Doctor</a>
</div>

<div class="table-responsive shadow-sm rounded p-3 bg-white">
    <table class="table table-striped table-hover mt-3 border datatable">
        <thead class="bg-light">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.Specialty)</th>
                <th>@Html.DisplayNameFor(model => model.Contact)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Specialty)</td>
                <td>@Html.DisplayFor(modelItem => item.Contact)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
