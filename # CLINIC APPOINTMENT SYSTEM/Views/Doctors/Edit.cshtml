@model ClinicAppointmentSystem.Models.Doctor

@{
    ViewData["Title"] = "Edit Doctor";
}

<h2>Edit Doctor</h2>
<hr />
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="MiddleName" class="form-label"></label>
            <input asp-for="MiddleName" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Specialty" class="form-label">Specialty</label>
        <input asp-for="Specialty" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Qualifications" class="form-label">Qualifications</label>
        <input asp-for="Qualifications" class="form-control" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Department" class="form-label">Department</label>
            <input asp-for="Department" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Contact" class="form-label">Contact Phone</label>
            <input asp-for="Contact" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="ConsultationHours" class="form-label">Consultation Hours</label>
        <input asp-for="ConsultationHours" class="form-control" />
    </div>

    <div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
