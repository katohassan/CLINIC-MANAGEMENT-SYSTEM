@model ClinicAppointmentSystem.Models.Appointment

@{
    ViewData["Title"] = "Cancel Appointment";
}

<h2>Cancel / Delete Appointment</h2>

<h3>Are you sure you want to cancel or delete this?</h3>
<div class="card bg-light mt-4 shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class = "col-sm-2">Patient</dt>
            <dd class = "col-sm-10">@(Model.Patient?.Name)</dd>
            <dt class = "col-sm-2">Doctor</dt>
            <dd class = "col-sm-10">@(Model.Doctor?.Name)</dd>
            <dt class = "col-sm-2">@Html.DisplayNameFor(model => model.Date)</dt>
            <dd class = "col-sm-10">@Model.Date.ToShortDateString()</dd>
            <dt class = "col-sm-2">@Html.DisplayNameFor(model => model.Time)</dt>
            <dd class = "col-sm-10">@Model.Time</dd>
            <dt class = "col-sm-2">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class = "col-sm-10"><span class="badge bg-danger">@Html.DisplayFor(model => model.Status)</span></dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-4" onsubmit="return confirm('Are you absolutely sure you want to delete this appointment? This action cannot be undone.');">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
