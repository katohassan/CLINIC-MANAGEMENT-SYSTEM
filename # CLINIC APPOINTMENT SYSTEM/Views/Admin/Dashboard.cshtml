@model ClinicAppointmentSystem.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mt-4 mb-4">Admin Dashboard</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3 shadow-sm rounded">
            <div class="card-header">Total Patients</div>
            <div class="card-body">
                <h3 class="card-title">@Model.TotalPatients</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3 shadow-sm rounded">
            <div class="card-header">Total Doctors</div>
            <div class="card-body">
                <h3 class="card-title">@Model.TotalDoctors</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3 shadow-sm rounded">
            <div class="card-header">Total Appointments</div>
            <div class="card-body">
                <h3 class="card-title">@Model.TotalAppointments</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3 shadow-sm rounded">
            <div class="card-header">Pending Appointments</div>
            <div class="card-body">
                <h3 class="card-title">@Model.PendingAppointments</h3>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-header bg-dark text-white border-0 py-3 rounded-top-4">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-calendar-day me-2"></i> Recent Appointments</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 border-0">
                        <thead class="bg-light text-muted">
                            <tr>
                                <th class="ps-4">Date</th>
                                <th>Time</th>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RecentAppointments)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium text-dark">@item.Date.ToShortDateString()</td>
                                    <td><i class="fa-regular fa-clock text-secondary me-1"></i> @item.Time</td>
                                    <td>@(item.Patient?.Name ?? "N/A")</td>
                                    <td>@(item.Doctor?.Name ?? "N/A")</td>
                                    <td>
                                        <span class="badge rounded-pill @(item.Status == "Pending" ? "bg-warning" : item.Status == "Approved" ? "bg-success" : item.Status == "Cancelled" ? "bg-danger" : "bg-primary") px-3">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Render C# View Component -->
    <div class="col-lg-4 mb-4">
        @await Component.InvokeAsync("RecentActivity")
    </div>
</div>
