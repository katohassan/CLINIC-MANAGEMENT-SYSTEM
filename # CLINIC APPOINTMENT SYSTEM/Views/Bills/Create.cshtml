@model ClinicAppointmentSystem.Models.Bill

@{
    ViewData["Title"] = "Create Invoice";
    var selectedAppointment = ViewData["SelectedAppointment"] as ClinicAppointmentSystem.Models.Appointment;
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        max-width: 800px;
        margin: 50px auto;
    }

    .form-label { font-weight: bold; color: #444; }
    
    .appointment-info {
        background: rgba(255, 255, 255, 0.7);
        border-right: 4px solid #4285f4;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
    }

    .btn-submit {
        background: #4285f4;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(66, 133, 244, 0.4); }
</style>

<div class="container">
    <div class="glass-card">
        <h2 class="fw-bold mb-4">Generate New Invoice</h2>

        @if (selectedAppointment != null)
        {
            <div class="appointment-info shadow-sm">
                <div class="row">
                    <div class="col-sm-6">
                        <small class="text-muted d-block uppercase small fw-bold">Patient</small>
                        <span class="h5">@selectedAppointment.Patient?.Name</span>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block uppercase small fw-bold">Appointment Date</small>
                        <span class="h5">@selectedAppointment.Date.ToString("f")</span>
                    </div>
                </div>
            </div>
        }

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            
            @if (selectedAppointment == null)
            {
                <div class="mb-4">
                    <label asp-for="AppointmentId" class="form-label">Select Appointment</label>
                    <select asp-for="AppointmentId" class="form-select rounded-pill p-2" asp-items="ViewBag.AppointmentId"></select>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="AppointmentId" value="@selectedAppointment.Id" />
            }

            <div class="row mb-4">
                <div class="col-md-6">
                    <label asp-for="TotalAmount" class="form-label">Total Amount Due ($)</label>
                    <input asp-for="TotalAmount" class="form-control rounded-pill p-2" step="0.01" />
                    <span asp-validation-for="TotalAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label">Initial Status</label>
                    <select asp-for="Status" class="form-select rounded-pill p-2">
                        <option value="Pending">Pending</option>
                        <option value="Paid">Paid (Cash/Card at clinic)</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label">Billing Notes (Items, Discounts, etc.)</label>
                <textarea asp-for="Notes" class="form-control rounded-4" rows="3" placeholder="Consultation fee, lab tests, etc."></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-link text-muted text-decoration-none">Cancel</a>
                <button type="submit" class="btn btn-submit shadow">Generate Invoice</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
