@model IEnumerable<ClinicAppointmentSystem.Models.Staff>
@{
    ViewData["Title"] = "Staff";
}
<h2>Staff</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New Staff</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Staff ID</th>
            <th>Full Name</th>
            <th>Role</th>
            <th>Department</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
    <tr>
        <td>@item.StaffId</td>
        <td>@item.FullName</td>
        <td>@item.Role</td>
        <td>@item.Department</td>
        <td>@item.Phone</td>
        <td>
            <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
            <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
            <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>
