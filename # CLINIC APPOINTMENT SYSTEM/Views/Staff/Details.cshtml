@model ClinicAppointmentSystem.Models.Staff

@{
    ViewData["Title"] = "Staff Details";
}

<h2>Staff Details</h2>
<hr />
<dl class="row">
    <dt class="col-sm-3">Staff ID</dt>
    <dd class="col-sm-9">@Model.StaffId</dd>

    <dt class="col-sm-3">Full Name</dt>
    <dd class="col-sm-9">@Model.FullName</dd>

    <dt class="col-sm-3">Role</dt>
    <dd class="col-sm-9">@Model.Role</dd>

    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.Department</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Phone</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
</dl>

<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</p>
