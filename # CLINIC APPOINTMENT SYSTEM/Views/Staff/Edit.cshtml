@model ClinicAppointmentSystem.Models.Staff

@{
    ViewData["Title"] = "Edit Staff";
}

<h2>Edit Staff</h2>
<hr />
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="MiddleName" class="form-label"></label>
            <input asp-for="MiddleName" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Role" class="form-label">Role</label>
        <input asp-for="Role" class="form-control" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Department" class="form-label">Department</label>
            <input asp-for="Department" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Phone" class="form-label">Phone</label>
            <input asp-for="Phone" class="form-control" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="EmploymentDate" class="form-label">Employment Date</label>
            <input asp-for="EmploymentDate" class="form-control" type="date" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="ShiftSchedule" class="form-label">Shift Schedule</label>
        <input asp-for="ShiftSchedule" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="AccessLevel" class="form-label">Access Level</label>
        <input asp-for="AccessLevel" class="form-control" />
    </div>

    <div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
