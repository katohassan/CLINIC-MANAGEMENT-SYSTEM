@model ClinicAppointmentSystem.Models.Staff

@{
    ViewData["Title"] = "Delete Staff";
}

<h2>Delete Staff</h2>
<hr />
<h3>Are you sure you want to delete this staff member?</h3>
<dl class="row">
    <dt class="col-sm-3">Staff ID</dt>
    <dd class="col-sm-9">@Model.StaffId</dd>
    <dt class="col-sm-3">Full Name</dt>
    <dd class="col-sm-9">@Model.FullName</dd>
    <dt class="col-sm-3">Role</dt>
    <dd class="col-sm-9">@Model.Role</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
