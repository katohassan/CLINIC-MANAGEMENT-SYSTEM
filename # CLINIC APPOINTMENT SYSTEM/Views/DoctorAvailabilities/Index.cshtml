@model IEnumerable<ClinicAppointmentSystem.Models.DoctorAvailability>

@{
    ViewData["Title"] = "Manage Doctor Availability";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Doctor Availability</h2>
    <a asp-action="Create" class="btn btn-primary">Add Time Slot</a>
</div>

<div class="table-responsive shadow-sm rounded p-3 bg-white">
    <table class="table table-striped table-hover mt-3 border datatable">
        <thead class="bg-light">
            <tr>
                <th>Doctor</th>
                <th>Day of Week</th>
                <th>Start Time</th>
                <th>End Time</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Doctor.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.DayOfWeek)</td>
                <td>@Html.DisplayFor(modelItem => item.StartTime)</td>
                <td>@Html.DisplayFor(modelItem => item.EndTime)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
