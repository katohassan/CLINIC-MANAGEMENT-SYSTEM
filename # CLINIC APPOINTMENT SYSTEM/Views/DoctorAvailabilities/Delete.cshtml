@model ClinicAppointmentSystem.Models.DoctorAvailability

@{
    ViewData["Title"] = "Delete Availability Slot";
}

<h2>Delete Availability Slot</h2>

<h3 class="text-danger mb-4">Are you sure you want to delete this time slot?</h3>
<div class="card shadow-sm p-4 col-md-6 mb-4">
    <h4>Availability Details</h4>
    <hr />
    <dl class="row mb-0">
        <dt class="col-sm-4">Doctor</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Doctor.Name)</dd>

        <dt class="col-sm-4">Day of Week</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.DayOfWeek)</dd>

        <dt class="col-sm-4">Start Time</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.StartTime)</dd>

        <dt class="col-sm-4">End Time</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.EndTime)</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
    <input type="submit" value="Delete Slot" class="btn btn-danger" />
</form>
