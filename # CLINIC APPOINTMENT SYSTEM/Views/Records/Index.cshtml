@model IEnumerable<ClinicAppointmentSystem.Models.Record>

@{
    ViewData["Title"] = "Patient Records";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Medical Records</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Record</a>
</div>

<div class="table-responsive shadow-sm rounded p-3 bg-white">
    <table class="table table-striped table-hover mt-3 border datatable">
        <thead class="bg-light">
            <tr>
                <th>Patient</th>
                <th>Doctor</th>
                <th>Date</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>@(item.Patient?.Name)</td>
                <td>@(item.Doctor?.Name)</td>
                <td>@item.Date.ToShortDateString()</td>
                <td>@(item.Notes.Length > 50 ? item.Notes.Substring(0, 50) + "..." : item.Notes)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
